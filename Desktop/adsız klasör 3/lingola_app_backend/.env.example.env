# Zorunlu (uygulama başlamadan kontrol edilir; test ortamında atlanır)
DATABASE_URL=postgresql://kadirkaratas@localhost:5432/lingola_db

# CORS: production'da frontend origin (virgülle birden fazla)
# Boş veya yoksa tüm origin'lere izin verilir (*)
# CORS_ORIGIN=https://myapp.com
# CORS_ORIGIN=https://app.example.com,https://www.example.com

# Ödeme/Abonelik (RevenueCat webhook doğrulama)
# RevenueCat Dashboard > Integrations > Webhooks > Authorization header ile aynı olmalı
# REVENUECAT_AUTH_HEADER=Bearer your-secret-token

# MySQL (harici Lingola Job veritabanı için örnek)
# Gerçek değerleri .env içine yaz, bu dosyada ŞİFRE TUTMA.
# MYSQL_HOST=5.39.8.160
# MYSQL_PORT=3306
# MYSQL_DB=flywork1_lingolajob
# MYSQL_USER=flywork1_lingolajobUser
# MYSQL_PASSWORD=your-strong-password
